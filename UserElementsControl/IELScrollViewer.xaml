<UserControl
    x:Class="IEL.UserElementsControl.IELScrollViewer"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:IEL.UserElementsControl">
    <Grid x:FieldModifier="private" x:Name="MainGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <Rectangle x:FieldModifier="private" x:Name="RectangleHorizontalScroll" Fill="White" RadiusX="5" RadiusY="5" HorizontalAlignment="Left" Height="{Binding Height, ElementName=ContainerHorizontalScroll}" Canvas.Left="0" Canvas.Top="0"/>
        <Rectangle x:FieldModifier="private" x:Name="RectangleVerticalScroll" Fill="White" VerticalAlignment="Top" RadiusX="5" RadiusY="5" Width="{Binding Width, ElementName=ContainerVerticalScroll}" Canvas.Left="0" Canvas.Top="0" Grid.Row="1" Grid.Column="1"/>
        <Rectangle x:FieldModifier="private" x:Name="Plug" Grid.Row="0" Fill="Black" Grid.Column="1" StrokeThickness="0" Margin="1,1,1,1"/>
        <Border x:FieldModifier="private" x:Name="UserControlContent" Grid.Row="1"/>
    </Grid>
</UserControl>
